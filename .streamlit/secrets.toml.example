# Copy to secrets.toml and fill in values
# On Streamlit Cloud: Settings > Secrets

# Login credentials
LOGIN_EMAIL = "admin@example.com"
LOGIN_PASSWORD = "your_password"

FABRIC_SERVER = "your-server.datawarehouse.fabric.microsoft.com"
FABRIC_DATABASE = "your_database"

# Service Principal (for Streamlit Cloud)
AZURE_TENANT_ID = ""
AZURE_CLIENT_ID = ""
AZURE_CLIENT_SECRET = ""
